      <string notr="true">
QMainWindow {
    background-color: #151518;
}
QWidget#centralwidget {
    background-color: #0f0f11;
}
QFrame {
    border: none;
}
QLabel {
    color: #d1d1d6;
    font-family: 'Segoe UI', 'Roboto', 'Arial';
    font-size: 13px;
}
QLabel#label_main_title {
    color: #00d2ff;
    font-size: 18px;
    font-weight: bold;
    letter-spacing: 1px;
    margin-bottom: 2px;
}
QLabel#label_subtitle {
    color: #8e8e93;
    font-size: 11px;
    margin-bottom: 10px;
}
QLabel#label_cam1_title {
    color: #00d2ff;
    font-weight: bold;
    font-size: 12px;
    background-color: #1a1a1f;
    padding: 6px;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    border: 1px solid #2e2e38;
    border-bottom: none;
}
QLabel#window_camera_1 {
    background-color: #000000;
    border: 1px solid #2e2e38;
    border-bottom-left-radius: 6px;
    border-bottom-right-radius: 6px;
}
QGroupBox {
    color: #00d2ff;
    font-weight: bold;
    font-size: 12px;
    border: 1px solid #2e2e38;
    border-radius: 6px;
    margin-top: 12px;
    padding: 12px 8px 8px 8px;
    background-color: #151518;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 10px;
    padding: 0 5px;
}
QPushButton {
    background-color: #24242b;
    color: #ffffff;
    border: 1px solid #3a3a45;
    border-radius: 4px;
    padding: 6px 12px;
    font-weight: bold;
    font-size: 12px;
    min-height: 24px;
}
QPushButton:hover {
    background-color: #2e2e38;
    border-color: #00d2ff;
}
QPushButton:pressed {
    background-color: #00d2ff;
    color: #0f0f11;
}
QPushButton:disabled {
    background-color: #121215;
    color: #555560;
    border-color: #202025;
}
QPushButton#btn_record_start {
    background-color: #1e3d2f;
    border-color: #2d5c47;
    color: #3df2a5;
}
QPushButton#btn_record_start:hover {
    background-color: #274f3d;
    border-color: #3df2a5;
}
QPushButton#btn_record_stop {
    background-color: #4a1d1d;
    border-color: #702b2b;
    color: #ff5c5c;
}
QPushButton#btn_record_stop:hover {
    background-color: #5e2424;
    border-color: #ff5c5c;
}
QTableWidget {
    background-color: #1a1a1f;
    color: #d1d1d6;
    gridline-color: #2e2e38;
    border: 1px solid #2e2e38;
    border-radius: 4px;
    alternate-background-color: #202025;
    font-size: 11px;
}
QHeaderView::section {
    background-color: #24242b;
    color: #00d2ff;
    padding: 6px;
    border: 1px solid #151518;
    font-weight: bold;
    font-size: 11px;
}
QTableWidget::item {
    padding: 4px;
}
QTableWidget::item:selected {
    background-color: #00d2ff;
    color: #0f0f11;
}
QScrollBar:vertical {
    border: none;
    background: #151518;
    width: 8px;
    margin: 0px;
}
QScrollBar::handle:vertical {
    background: #2e2e38;
    min-height: 20px;
    border-radius: 4px;
}
QScrollBar::handle:vertical:hover {
    background: #00d2ff;
}
QCheckBox {
    color: #d1d1d6;
    spacing: 6px;
    font-size: 12px;
}
QCheckBox::indicator {
    width: 14px;
    height: 14px;
    border: 1px solid #3a3a45;
    border-radius: 3px;
    background-color: #1a1a1f;
}
QCheckBox::indicator:checked {
    background-color: #00d2ff;
    border-color: #00d2ff;
}
</string>
